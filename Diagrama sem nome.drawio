          <mxGeometry height="60" width="120" x="500" y="369.995" as="geometry" />
        </mxCell>
        <mxCell id="l4Nygw93mPyC54p-94k8-24" parent="1" style="whiteSpace=wrap;html=1;rounded=0;fillColor=#d5e8d4;strokeColor=#82b366;" value="6. CASHBACK" vertex="1">
          <mxGeometry height="60" width="120" x="720" y="369.995" as="geometry" />
        </mxCell>
        <mxCell id="l4Nygw93mPyC54p-94k8-26" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;TOTEM&lt;/font&gt;&lt;/h1&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;O TOTEM SERÁ UMA FORMA DOS CLIENTES TEREM UM ATENDIMENTO RÁPIDO, FACIL E DINÂMICO NA LIVRARIA&amp;nbsp;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;1. &lt;u&gt;LOGIN&lt;/u&gt;: O LOGIN É PARA O CLIENTE TER UM CADASTRO DIRETO COM A LOJA, E É UMA FORMA DE ASSOCIAR OS BENEFICIOS DO CASHBACK AO CLIENTE.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;2. &lt;u&gt;GOSTO DO CLIENTE&lt;/u&gt;: APÓS O LOGIN O CLIENTE É DIRETAMENTE DIRECIONADO PARA UMA ABA&amp;nbsp; DE CATEGORIAS DE LIVROS, ONDE É FILTRADO OS INTERESSES LITERÁRIOS DO CLIENTE.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;3. &lt;u&gt;CATALOGO DE LIVROS&lt;/u&gt;: AQUI O CLIENTE TERÁ ACESSO A UM CATALOGO TOTALMENTE PERSONALIZADO POR ELE, PORÉM ELE TAMBÉM TERÁ UMA BARRA DE PESQUISA QUE PROPORCIONARA AO CLIENTE ACESSO A TODO O ESTOQUE DA LIVRARIA.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;4. &lt;u&gt;CÓDIGO PARA RETIRADA&lt;/u&gt;: APÓS A ESCOLHA DO (OU DOS) LIVRO(OS) O TOTEM IRÁ PROPORCIONAR UM CÓDIGO IMPRESSO PARA O CLIENTE PAGAR E RETIRAR O LIVRO NO CAIXA.&amp;nbsp;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;&amp;nbsp;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font size=&quot;3&quot;&gt;&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="520" width="410" x="20" y="360" as="geometry" />
        </mxCell>
        <mxCell id="l4Nygw93mPyC54p-94k8-27" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;SISTEMA DE CONTROLE&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;O SISTEMA&amp;nbsp; DE CONTROLE SERÁ UM SISTEMA HÍBRIDO. NELE TERÁ ACESSO A VÁRIAS FUNÇÕES DE CONTROLE DA LIVRARIA.&amp;nbsp;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;1. &lt;u&gt;MENU DE CONTROLE&lt;/u&gt;: AO ABRIR O SISTEMA PODERÁ LOCALIZAR&amp;nbsp; E ACESSAR TODAS AS FUNÇÕES DE CONTROLE.&amp;nbsp;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;2. &lt;u&gt;CONTROLE DE ENTRADA&lt;/u&gt;: AQUI O LOJISTA PODERÁ REGISTRA A ENTRADA DE TODOS OS LIVROS DE ESTOQUE.&amp;nbsp;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;3. &lt;u&gt;CONTROLE DE SAÍDA&lt;/u&gt;: ESSA ABA É DIRETAMENTE LIGADA AO &lt;b&gt;CÓDIGO DE RETIRADA, &lt;/b&gt;O LOJISTA IRÁ INSERIR O CÓDIGO NO SISTEMA, E ISSO POSSIBILITARÁ O LOJISTA IDENTIFICAR O LIVRO PARA O CLIENTE.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;4. &lt;u&gt;PAGAMENTO&lt;/u&gt;: AQUI O CLIENTE PODERÁ EFETUAR O PAGAMENTO PARA A LIVRARIA E OS DADOS DA VENDA (LIVRO ADERIDO, FORMA DE PAGAMENTO ESCOLHIDA PELO CLIENTE) IRÂO DIRETO PARA O FLUXO DE CAIXA.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;5. &lt;u&gt;FLUXO DE CAIXA&lt;/u&gt;: NESTA ABA O LOJISTA TERÁ CONTROLE DE TODAS AS VENDAS RELACIONADA AOS LIVROS E AOS CAFÉS VENDIDOS NA LOJA. OS DADOS SÃO ATUALIZADOS A CADA FECHAMENTO DE CAIXA&amp;nbsp;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="755" width="370" x="480" y="465" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
