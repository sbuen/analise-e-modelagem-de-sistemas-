        </mxCell>
        <mxCell id="l4Nygw93mPyC54p-94k8-42" edge="1" parent="1" source="l4Nygw93mPyC54p-94k8-24" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;fillColor=#d5e8d4;strokeColor=#82b366;" target="l4Nygw93mPyC54p-94k8-41">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="l4Nygw93mPyC54p-94k8-24" parent="1" style="whiteSpace=wrap;html=1;rounded=0;fillColor=#d5e8d4;strokeColor=#82b366;gradientColor=light-dark(#ffe6cc, #655544);gradientDirection=east;" value="6. CASHBACK" vertex="1">
          <mxGeometry height="60" width="120" x="870" y="369.995" as="geometry" />
        </mxCell>
        <mxCell id="l4Nygw93mPyC54p-94k8-26" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;TOTEM&lt;/font&gt;&lt;/h1&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;O TOTEM SERÁ UMA FORMA DOS CLIENTES TEREM UM ATENDIMENTO RÁPIDO, FACIL E DINÂMICO NA LIVRARIA&amp;nbsp;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;1. &lt;u&gt;LOGIN&lt;/u&gt;: O LOGIN É PARA O CLIENTE TER UM CADASTRO DIRETO COM A LOJA, E É UMA FORMA DE ASSOCIAR OS BENEFICIOS DO CASHBACK AO CLIENTE.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;2. &lt;u&gt;GOSTO DO CLIENTE&lt;/u&gt;: APÓS O LOGIN O CLIENTE É DIRETAMENTE DIRECIONADO PARA UMA ABA&amp;nbsp; DE CATEGORIAS DE LIVROS, ONDE É FILTRADO OS INTERESSES LITERÁRIOS DO CLIENTE.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;3. &lt;u&gt;CATALOGO DE LIVROS&lt;/u&gt;: AQUI O CLIENTE TERÁ ACESSO A UM CATALOGO TOTALMENTE PERSONALIZADO POR ELE, PORÉM ELE TAMBÉM TERÁ UMA BARRA DE PESQUISA QUE PROPORCIONARA AO CLIENTE ACESSO A TODO O ESTOQUE DA LIVRARIA.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;4. &lt;u&gt;CÓDIGO PARA RETIRADA&lt;/u&gt;: APÓS A ESCOLHA DO (OU DOS) LIVRO(OS) O TOTEM IRÁ PROPORCIONAR UM CÓDIGO IMPRESSO PARA O CLIENTE PAGAR E RETIRAR O LIVRO NO CAIXA.&amp;nbsp;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;&amp;nbsp;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;font size=&quot;3&quot;&gt;&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="520" width="410" x="20" y="360" as="geometry" />
        </mxCell>
        <mxCell id="l4Nygw93mPyC54p-94k8-27" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;SISTEMA DE CONTROLE&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;O SISTEMA&amp;nbsp; DE CONTROLE SERÁ UM SISTEMA HÍBRIDO. NELE TERÁ ACESSO A VÁRIAS FUNÇÕES DE CONTROLE DA LIVRARIA.&amp;nbsp;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;1. &lt;u&gt;MENU DE CONTROLE&lt;/u&gt;: AO ABRIR O SISTEMA PODERÁ LOCALIZAR&amp;nbsp; E ACESSAR TODAS AS FUNÇÕES DE CONTROLE.&amp;nbsp;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;2. &lt;u&gt;CONTROLE DE ENTRADA&lt;/u&gt;: AQUI O LOJISTA PODERÁ REGISTRA A ENTRADA DE TODOS OS LIVROS DE ESTOQUE.&amp;nbsp;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;3. &lt;u&gt;CONTROLE DE SAÍDA&lt;/u&gt;: ESSA ABA É DIRETAMENTE LIGADA AO &lt;b&gt;CÓDIGO DE RETIRADA, &lt;/b&gt;O LOJISTA IRÁ INSERIR O CÓDIGO NO SISTEMA, E ISSO POSSIBILITARÁ O LOJISTA IDENTIFICAR O LIVRO PARA O CLIENTE.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;4. &lt;u&gt;PAGAMENTO&lt;/u&gt;: AQUI O CLIENTE PODERÁ EFETUAR O PAGAMENTO PARA A LIVRARIA E OS DADOS DA VENDA (LIVRO ADERIDO, FORMA DE PAGAMENTO ESCOLHIDA PELO CLIENTE) IRÂO DIRETO PARA O FLUXO DE CAIXA.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;5. &lt;u&gt;FLUXO DE CAIXA&lt;/u&gt;: NESTA ABA O LOJISTA TERÁ CONTROLE DE TODAS AS VENDAS RELACIONADA AOS LIVROS E AOS CAFÉS VENDIDOS NA LOJA. OS DADOS SÃO ATUALIZADOS A CADA FECHAMENTO DE CAIXA&amp;nbsp;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;6. &lt;u&gt;CASHBACK&lt;/u&gt;: APÓS A VENDAQ O CLIENTE QUE FEZ O LOGIN LÁ NO TOTEM, VAI TER ANEXADO EM SEU CPF UM CUPOM DE 10% DO VALOR DA COMPRA PARA UTILIZAR NA COMPRA DE OUTROS LIVROS OU PARA COMPRAR CAFÉS OU SALGADOS NA CAFETERIA DA LOJA&amp;nbsp;&lt;/font&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="795" width="370" x="480" y="465" as="geometry" />
        </mxCell>
        <mxCell id="l4Nygw93mPyC54p-94k8-29" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#d79b00;fillColor=#ffe6cc;align=center;verticalAlign=middle;rounded=0;" value="&lt;span style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;SISTEMA CAFETERIA&amp;nbsp;&lt;/b&gt;&lt;/span&gt;" vertex="1">
          <mxGeometry height="40" width="280" x="1010" as="geometry" />
        </mxCell>
        <mxCell id="l4Nygw93mPyC54p-94k8-32" edge="1" parent="1" source="l4Nygw93mPyC54p-94k8-30" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" target="l4Nygw93mPyC54p-94k8-31" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="l4Nygw93mPyC54p-94k8-30" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="1. MENU DE VENDA&amp;nbsp;" vertex="1">
          <mxGeometry height="60" width="120" x="1100" y="60" as="geometry" />
        </mxCell>
        <mxCell id="l4Nygw93mPyC54p-94k8-43" edge="1" parent="1" source="l4Nygw93mPyC54p-94k8-31" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fillColor=#ffe6cc;strokeColor=#d79b00;" target="l4Nygw93mPyC54p-94k8-33">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="l4Nygw93mPyC54p-94k8-44" edge="1" parent="1" source="l4Nygw93mPyC54p-94k8-31" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fillColor=#ffe6cc;strokeColor=#d79b00;" target="l4Nygw93mPyC54p-94k8-41">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="l4Nygw93mPyC54p-94k8-31" parent="1" style="whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;rounded=0;" value="2. POSSIVES ALTERAÇÕES NO PEDIDO&amp;nbsp;" vertex="1">
          <mxGeometry height="60" width="120" x="1100" y="190" as="geometry" />
        </mxCell>
        <mxCell id="l4Nygw93mPyC54p-94k8-37" edge="1" parent="1" source="l4Nygw93mPyC54p-94k8-33" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.25;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;fillColor=#ffe6cc;strokeColor=#d79b00;" target="l4Nygw93mPyC54p-94k8-19">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="l4Nygw93mPyC54p-94k8-33" parent="1" style="whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;rounded=0;" value="4. PAGAMENTO" vertex="1">
          <mxGeometry height="60" width="120" x="1040" y="309.99" as="geometry" />
        </mxCell>
        <mxCell id="l4Nygw93mPyC54p-94k8-38" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#ffe6cc;strokeColor=#d79b00;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;font style=&quot;font-size: 24px;&quot;&gt;SISTEMA CAFETERIA&lt;/font&gt;&lt;/h1&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;ESSE SISTEMA SERÁ UM SISTEMA SIMPLES DE VENDA&amp;nbsp; PARA OS ATENDENTES TEREM UM SERVIÇO OTIMIZADO&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;1. &lt;u&gt;MENU DE VENDA&lt;/u&gt;: O ATENDENTE INICIARÁ O ATENDIMENTO COM TODO O CARDPIO DA CAFETERIA NO SISTEMA.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;2. &lt;u&gt;POSSIVEIS ALTERAÇÕES NO PEDIDO&lt;/u&gt;: AQUI É UMA ABA&amp;nbsp; PARA ESPECIFICAR ALGUMA POSSIVEL RESTRIÇÃO ALIMENTAR DO CLIENTE, OU UMA POSSIVEL MODIFICAÇÃO EM ALGUM INTEM DO MENU.&amp;nbsp;&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;3. &lt;u&gt;CPF&lt;/u&gt;: AQUI É ONDE O SISTEMA IRÁ VINCULAR O DESCONTO DO CASHBACK DA COMPRA DO&amp;nbsp; LIVRO AO PAGAMENTO DO CAFÉ. LEMBRANDO QUE O CLIENTE NÃO NECESSARIA MENTE É OBRIGADO TER COMPRADO UM LIVRO ANTES, OU POR ALGUM MOTIVO NÃO QUER UTILIZAR O CASHBACK. LOGO ESSA OPÇÃO NÃO É OBRIGATÓRIA.&lt;/font&gt;&lt;/p&gt;&lt;p&gt;&lt;font size=&quot;3&quot;&gt;4. &lt;u&gt;PAGAMENTO&lt;/u&gt;: SE O CLIENTE VINCULOU O CPF DELE, ENTÂO, DE FORMA AUTOMATICA, O DESCONTO É APLICADO NA COMPRA. MAS SE O CLIENTE NÃO VINCULAR O CPF NO PAGAMENTO, ELE TERÁ QUE PAGAR O VALOR INTEGRAL DA COMPRA . TODAS AS VENDAS EFETUADAS SÃO DIRETAMENTE LANÇADAS AO FLUXO DE CAIXA .&lt;/font&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="605" width="410" x="950" y="465" as="geometry" />
        </mxCell>
        <mxCell id="l4Nygw93mPyC54p-94k8-45" edge="1" parent="1" source="l4Nygw93mPyC54p-94k8-41" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;fillColor=#ffe6cc;strokeColor=#d79b00;" target="l4Nygw93mPyC54p-94k8-33">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="l4Nygw93mPyC54p-94k8-41" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" value="3. CPF" vertex="1">
          <mxGeometry height="60" width="120" x="1210" y="309.99" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
